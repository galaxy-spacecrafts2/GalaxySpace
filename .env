# ===========================================
# GALAXY SPACECRAFTS - PRODUCTION SECURITY CONFIG
# ===========================================
# NUNCA compartilhe este arquivo ou envie para repositórios públicos
# Mantenha estas variáveis em segredo absoluto

# ===========================================
# DATABASE SECURITY
# ===========================================
# Use strings de conexão criptografadas e IPs permitidos
DATABASE_URL="postgresql://username:password@localhost:5432/galaxy_space?sslmode=require&sslcert=/path/to/cert&sslkey=/path/to/key"
DATABASE_POOL_MIN=10
DATABASE_POOL_MAX=20
DATABASE_TIMEOUT=30000

# ===========================================
# AUTHENTICATION & SESSION SECURITY
# ===========================================
# Chaves de 256+ bits, geradas com: openssl rand -base64 32
BETTER_AUTH_SECRET="your-super-secure-256-bit-secret-key-here-minimum-32-chars"
BETTER_AUTH_URL="https://your-domain.com"
SESSION_SECRET="your-session-secret-minimum-32-characters-long"
JWT_SECRET="your-jwt-secret-minimum-256-bits-long"

# Configurações de sessão seguras
SESSION_TIMEOUT=3600000
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTP_ONLY=true
SESSION_COOKIE_SAME_SITE=strict

# ===========================================
# ENCRYPTION KEYS
# ===========================================
# Chaves AES-256 para criptografia de dados sensíveis
ENCRYPTION_KEY="your-256-bit-encryption-key-here"
DATA_ENCRYPTION_IV="your-16-byte-initialization-vector"

# ===========================================
# API SECURITY
# ===========================================
# Rate limiting
API_RATE_LIMIT=100
API_RATE_WINDOW=900000
STRICT_RATE_LIMIT=true

# CORS restritivo
ALLOWED_ORIGINS="https://your-domain.com,https://www.your-domain.com"
ALLOWED_METHODS="GET,POST,PUT,DELETE,OPTIONS"
ALLOWED_HEADERS="Content-Type,Authorization,X-Requested-With"

# ===========================================
# EXTERNAL SERVICES SECURITY
# ===========================================
# OAuth providers (se usado)
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Email service (SMTP seguro)
SMTP_HOST="smtp.your-provider.com"
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER="your-smtp-username"
SMTP_PASS="your-smtp-password"

# ===========================================
# MONITORING & LOGGING
# ===========================================
# Services de monitoramento
SENTRY_DSN="https://your-sentry-dsn-here"
DATADOG_API_KEY="your-datadog-api-key"
LOGTAIL_TOKEN="your-logtail-token"

# Webhook para alertas de segurança
SECURITY_WEBHOOK_URL="https://your-security-monitoring.com/webhook"
SECURITY_WEBHOOK_SECRET="your-webhook-secret"

# ===========================================
# CDN & STORAGE SECURITY
# ===========================================
# Cloud storage
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="your-secure-bucket"
CDN_URL="https://cdn.your-domain.com"

# ===========================================
# REDIS/CACHE SECURITY
# ===========================================
REDIS_URL="redis://username:password@your-redis-host:6379"
REDIS_TLS=true
REDIS_PASSWORD="your-redis-password"

# ===========================================
# NEXT.JS SECURITY
# ===========================================
# Configurações de produção
NODE_ENV="production"
NEXT_PUBLIC_PLATFORM="web"
NEXT_PUBLIC_APP_URL="https://your-domain.com"

# Desativar debugging
NEXT_PUBLIC_DEBUG=false
NEXT_PUBLIC_DEVTOOLS=false

# ===========================================
# SECURITY HEADERS
# ===========================================
# CSP nonce generator
CSP_NONCE_SECRET="your-csp-nonce-secret"

# HSTS preload
HSTS_MAX_AGE=31536000
HSTS_INCLUDE_SUBDOMAINS=true
HSTS_PRELOAD=true

# ===========================================
# BACKUP & RECOVERY
# ===========================================
# Backup encryption
BACKUP_ENCRYPTION_KEY="your-backup-encryption-key"
BACKUP_STORAGE_URL="s3://your-backup-bucket"
BACKUP_SCHEDULE="0 2 * * *" # Daily at 2 AM

# ===========================================
# FIREWALL & NETWORK SECURITY
# ===========================================
# IPs permitidos para admin
ADMIN_ALLOWED_IPS="192.168.1.100,10.0.0.50,your-office-ip"

# Configurações de firewall
FIREWALL_ENABLED=true
FIREWALL_RULES="strict"

# ===========================================
# COMPLIANCE & AUDIT
# ===========================================
# Logs de auditoria
AUDIT_LOG_RETENTION=2592000 # 30 dias
AUDIT_LOG_ENCRYPTION=true

# GDPR compliance
GDPR_COMPLIANCE=true
DATA_RETENTION_DAYS=2555 # 7 anos
COOKIE_CONSENT_REQUIRED=true

# ===========================================
# PERFORMANCE MONITORING
# ===========================================
# APM (Application Performance Monitoring)
APM_SERVICE_NAME="galaxy-spacecrafts"
APM_ENVIRONMENT="production"
APM_SAMPLE_RATE=0.1

# ===========================================
# INCIDENT RESPONSE
# ===========================================
# Emergency contacts
SECURITY_TEAM_EMAIL="security@your-domain.com"
INCIDENT_RESPONSE_WEBHOOK="https://your-incident-response.com/webhook"

# Auto-block configuration
AUTO_BLOCK_ENABLED=true
AUTO_BLOCK_THRESHOLD=10
AUTO_BLOCK_DURATION=3600000 # 1 hora

# ===========================================
# DEVELOPMENT OVERRIDES (DISABLE IN PRODUCTION)
# ===========================================
# NUNCA use estas configurações em produção
DEV_MODE=false
DEBUG_MODE=false
LOG_LEVEL="error"
VERBOSE_LOGGING=false
ENABLE_SWAGGER=false
ENABLE_PLAYGROUND=false

# ===========================================
# MISCELLANEOUS SECURITY
# ===========================================
# Rate limiting específico
LOGIN_RATE_LIMIT=5
LOGIN_RATE_WINDOW=900000 # 15 minutos
REGISTER_RATE_LIMIT=3
REGISTER_RATE_WINDOW=1800000 # 30 minutos

# File upload security
MAX_FILE_SIZE=10485760 # 10MB
ALLOWED_FILE_TYPES="jpg,jpeg,png,pdf,doc,docx"
VIRUS_SCAN_ENABLED=true

# Password policies
MIN_PASSWORD_LENGTH=12
PASSWORD_EXPIRY_DAYS=90
PASSWORD_HISTORY_COUNT=5
FAILED_LOGIN_LOCKOUT=5
FAILED_LOGIN_WINDOW=900000

# ===========================================
# ENVIRONMENT VERIFICATION
# ===========================================
# Verificação de integridade
ENVIRONMENT_CHECKSUM="your-environment-checksum"
CONFIG_VERSION="1.0.0"
LAST_UPDATED="2024-01-01T00:00:00Z"

# supabase
NEXT_PUBLIC_SUPABASE_URL=https://ufrbhfcklrvgqxnhzjzd.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_DEFAULT_KEY=sb_publishable_ikZzckOX1u264Kju2ArTnA_Idg3O6z9
