{
  "name": "my-project",
  "version": "0.1.0",
  "description": "Galaxy SpaceCrafts - Rocket telemetry and mission control system",
  "author": "Galaxy SpaceCrafts Team",
  "private": true,
  "scripts": {
    "dev": "next dev -p 5000 -H 0.0.0.0",
    "build": "next build",
    "build:mobile": "cross-env NEXT_PUBLIC_PLATFORM=mobile next build",
    "start": "next start -p 5000 -H 0.0.0.0",
    "lint": "eslint .",
    "export": "next build",
    "export:mobile": "$env:NEXT_PUBLIC_PLATFORM='mobile'; node mobile-build-simple.js prepare; $env:NEXT_PUBLIC_PLATFORM='mobile'; npx next build; node mobile-build-simple.js restore; node next-static-export.js out",
    "cap:init": "cap init 'Galaxy SpaceCrafts' 'com.galaxy.spacecrafts' --web-dir=out",
    "cap:add:android": "cap add android",
    "cap:sync": "cap sync",
    "cap:open:android": "cap open android",
    "android:build": "npm run export:mobile && npm run cap:sync; Set-Location android; ./gradlew assembleDebug",
    "android:release": "npm run export:mobile && npm run cap:sync && cd android && ./gradlew assembleRelease",
    "electron:dev": "electron electron/main.js",
    "electron:build": "npm run build && electron-builder",
    "electron:build:win": "npm run build && electron-builder --win",
    "electron:build:mac": "npm run build && electron-builder --mac",
    "electron:build:linux": "npm run build && electron-builder --linux"
  },
